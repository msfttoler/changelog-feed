# Environment configuration for changelog-feed
# Copy this file to .env and fill in the values

# ── AI Classifier ────────────────────────────────────────────────────────────
# Set OPENAI_API_KEY to use OpenAI directly.
# For Azure OpenAI, set all three AZURE_OPENAI_* variables instead.

OPENAI_API_KEY=

# Azure OpenAI (alternative to OpenAI)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=       # e.g. https://my-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=     # e.g. gpt-4o

# Model to use when calling OpenAI (ignored for Azure, which uses DEPLOYMENT)
OPENAI_MODEL=gpt-4o

# ── Teams Workflow Webhook ────────────────────────────────────────────────────
# Paste the full URL from the Teams Workflow trigger (HTTP Request step)
TEAMS_WEBHOOK_URL=

# ── Relevance Threshold ───────────────────────────────────────────────────────
# Minimum CSA relevance level to post ("high", "medium", "low").
# Defaults to "high" – only items AI rates as high relevance are posted.
MIN_RELEVANCE=high

# ── State database path ───────────────────────────────────────────────────────
STATE_DB_PATH=.changelog_feed_state.db
